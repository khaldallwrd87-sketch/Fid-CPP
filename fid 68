
#include <iostream>
#include <vector>
#include <array>
using namespace std;

int main()
{
	int nums[6] = { 1, 2, 3, 4, 5 };
	cout << nums[3] << endl;
	nums[5] = 6;
	cout << nums[5] << endl;	
	cout << "-----------------------------" << endl;
	array<int, 6> arr = { 1, 2, 3, 4, 5 };
	arr[5] = 6;
	cout << arr[5] << endl;
	return 0;
}
