
#include <iostream>
#include <vector>
#include <array>
#include <algorithm>
using namespace std;

int main()
{
	int num = 100;
	int* ptr = &num;
	cout << "Value of num: " << num << endl;
	cout << "Address of num: " << &num << endl;
	cout << "Value of ptr: " << ptr << endl;
	cout << "Value pointed to by ptr: " << *ptr << endl;
	*ptr = 200;
	cout << "Value of num: " << num << endl;
	cout << "Address of num: " << &num << endl;
	cout << "Value of ptr: " << ptr << endl;
	cout << "Value pointed to by ptr: " << *ptr << endl;
	return 0;
}
